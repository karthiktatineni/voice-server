# ============================================
# Voice Agent Server - Environment Variables
# ============================================
# Copy this file to .env and fill in your values.

# --- Server ---
PORT=3001
NODE_ENV=development

# --- Groq (LLM) ---
GROQ_API_KEY=

# --- Twilio ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
# The public URL of this server (Render URL). Twilio webhooks point here.
SERVER_BASE_URL=

# --- Deepgram (STT & TTS) ---
DEEPGRAM_API_KEY=

# --- Firebase Admin ---
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
# OR provide the full JSON:
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account",...}

# --- Security ---
# Shared secret between Vercel frontend and this server
API_SECRET_KEY=
